   "source": [
    "# Convert vacancies/ion to dpa/10^16 ions/cm^2\n",
    "F0 = 1e16;  # ion flux\n",
    "dx = (x[1]-x[0])*1e-7 # x grid step in cm \n",
    "\n",
    "# Plot\n",
    "plt.figure()\n",
    "plt.plot(x*1e-3, v*(F0/dx/Nfe))\n",
    "plt.xlabel(\"depth (μm)\")\n",
    "plt.ylabel(r\"Dpa $\\div$ ion fluence [10$^{16}$ cm$^{-2}$]\")\n",
    "plt.title(\"2 MeV Fe in Fe: Displacement Damage Profile\")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
