   "id": "read-md",
   "metadata": {},
   "source": [
    "## 5. Read data from HDF5 output file"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 40,
   "id": "read",
   "metadata": {},
   "outputs": [],
   "source": [
    "h5_path = tmppath / \"result.h5\"\n",
    "if not h5_path.exists():\n",
    "    raise FileNotFoundError(f\"Expected output file not found: {h5_path}\")\n",
    "\n",
    "with h5py.File(h5_path, \"r\") as f:\n",
    "    data = np.asarray(f[\"/user_tally/AngularDistribution/data\"][...])  # (1,20,1)\n",
    "    nx_bins = np.asarray(f[\"/user_tally/AngularDistribution/bins/1\"][...])  # length 21\n",
    "\n",
    "    theta = np.sqrt(1.0 - nx_bins**2) # sqrt(1-(cosθ)^2)=sinθ ~ θ\n",
    "    theta_deg = np.degrees(theta[:-1])\n",
    "    delta_cos = nx_bins[1:] - nx_bins[:-1]\n",
    "    S = data[0, :, 0] / delta_cos / (4.0 * np.pi)"
   ]
  },
